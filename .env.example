# Postgres (local Docker)
DATABASE_URL="postgresql://chess:chess@localhost:5433/chess?schema=public"

# Better Auth
AUTH_SECRET="generate-a-32-byte-random-string"

# Base URL of the app (used for server-side fetches during signup)
BETTER_AUTH_URL="http://localhost:3000"

# Test DB (separate database for isolated test runs)
TEST_DATABASE_URL="postgresql://chess:chess@localhost:5433/chess_test?schema=public"

# Cron protection
CRON_SECRET="generate-another-random-string"

# Lichess OAuth (PKCE — no client secret needed).
# Register an app at https://lichess.org/account/oauth/app to get a client ID.
# Set the redirect URI to: http://localhost:3000/api/auth/lichess/callback
LICHESS_CLIENT_ID="chess-lms-dev"
